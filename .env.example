# Solana RPC URL (use a fast, paid RPC for production)
RPC_URL=https://api.mainnet-beta.solana.com

# Your wallet keypair (base58 encoded private key)
PRIVATE_KEY=your_base58_private_key_here

# Telegram Bot Token (from @BotFather)
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Telegram Chat ID (where to send signals)
CHAT_ID=your_telegram_chat_id_here

# Jito Block Engine URL
JITO_ENDPOINT=https://mainnet.block-engine.jito.wtf/api/v1/transactions

# Jito Tip lamports (optional, for faster inclusion)
JITO_TIP_LAMPORTS=50000
